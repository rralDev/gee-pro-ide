{
  "name": "gee-pro-ide",
  "displayName": "GEE Pro IDE",
  "description": "Professional Google Earth Engine IDE for VS Code with integrated Map, Console, and AI Assistant.",
  "version": "0.1.3",
  "publisher": "LuisRobles",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "google earth engine",
    "gee",
    "gis",
    "remote sensing",
    "geospatial",
    "satellite imagery",
    "earth observation",
    "mapping",
    "spatial analysis",
    "javascript api"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gee-pro.start",
        "title": "Start Environment",
        "category": "GEE Pro IDE"
      },
      {
        "command": "gee-pro.login",
        "title": "Login with Google (Easy)",
        "category": "GEE Pro IDE"
      },
      {
        "command": "gee-pro.runAll",
        "title": "Run Entire Script",
        "category": "GEE Pro IDE"
      },
      {
        "command": "gee-pro.reset",
        "title": "Reset Environment",
        "category": "GEE Pro IDE"
      },
      {
        "command": "gee-pro.getLink",
        "title": "GEE Pro IDE: Get Shareable Link",
        "category": "GEE Pro IDE"
      }
    ],
    "keybindings": [
      {
        "command": "gee-pro.run",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus"
      },
      {
        "command": "gee-pro.runAll",
        "key": "cmd+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gee-pro.run",
          "when": "resourceExtname == .js",
          "group": "navigation"
        },
        {
          "command": "gee-pro.runSelection",
          "when": "resourceExtname == .js",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gee-pro-sidebar",
          "title": "GEE Pro",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "gee-pro-sidebar": [
        {
          "id": "gee-pro-assets",
          "name": "Assets",
          "type": "tree"
        },
        {
          "id": "gee-pro-tasks",
          "name": "Tasks",
          "type": "tree"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rralDev/gee-pro-ide.git"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.17.11",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "@google/earthengine": "^0.1.350"
  }
}
